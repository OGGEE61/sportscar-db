# ── Database backend ──────────────────────────────────────────────────────────
# Set to "d1" to use Cloudflare D1, or leave as "sqlite" for local development.
DB_BACKEND=sqlite

# ── Cloudflare account ────────────────────────────────────────────────────────
# Found at: https://dash.cloudflare.com/ → right sidebar → Account ID
CF_ACCOUNT_ID=your_cloudflare_account_id_here

# ── D1 database ID ────────────────────────────────────────────────────────────
# Shown after running: wrangler d1 create sportscar-db
# Or at: Cloudflare Dashboard → Workers & Pages → D1 → your database → Settings
CF_D1_DATABASE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ── Cloudflare API token (D1 access) ─────────────────────────────────────────
# Create at: https://dash.cloudflare.com/profile/api-tokens
# Required permissions: D1:Edit (for the database above)
CF_API_TOKEN=your_cloudflare_api_token_here

# ── Cloudflare API token (Browser Rendering access) ───────────────────────────
# Can be the same token as CF_API_TOKEN if you combine permissions:
#   D1:Edit + Browser Rendering:Edit
# Or create a separate token with only Browser Rendering:Edit permission.
CF_BR_API_TOKEN=your_cloudflare_browser_rendering_token_here
